# Copia este fichero a .env y rellena los valores. NUNCA subas .env al repo.

# Clave de la API de Anthropic (vive SOLO en el servidor)
ANTHROPIC_API_KEY=sk-ant-...

# Secreto para firmar las cookies de sesión (genera uno largo y aleatorio)
SESSION_SECRET=pon-aqui-una-cadena-larga-y-aleatoria

# Usuarios del equipo y colaboradores: "usuario:contraseña" separados por comas.
# En producción real conviene migrar a una BD con contraseñas hasheadas.
APP_USERS=rosario:cambia-esto,colaborador1:otra-clave

# Puerto interno de la app (Caddy le habla por aquí; no se expone al exterior)
PORT=3000

# Horas que se conservan los .txt SUBIDOS (temporales) antes de borrarlos.
# OJO: los .docx/.pdf de outputs/ NO se borran: son el histórico de planes.
RETENTION_HOURS=48

# Dominio/subdominio público (para Caddy + HTTPS automático).
# Debe apuntar por DNS (registro A) a la IP de tu servidor.
DOMINIO=planes.tudominio.com

# NODE_ENV=production  # descomentar en producción (activa cookies seguras)
NODE_ENV=production
